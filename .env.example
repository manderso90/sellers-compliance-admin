# ============================================
# Seller's Compliance Admin — Environment Variables
# Copy to .env.local and fill in real values
# ============================================

# ── App ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: https://admin.sellerscompliance.com

# ── Supabase ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Service role key: Settings → API → service_role (secret)

# ── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
# Admin uses this for payment-link creation in lib/actions/payment-actions.ts
# Webhook (STRIPE_WEBHOOK_SECRET) stays on the public repo — not needed here.

# ── Resend (email) ───────────────────────────
RESEND_API_KEY=re_...
# Invite emails sent from /admin/settings

# ── Google Maps / Places ─────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
# Powers address autocomplete on /admin/jobs/new (AddressAutocomplete).
# Without this, the form falls back to a plain text input. Restrict the
# key in Google Cloud Console to the referrers admin.sellerscompliance.com/*
# and http://localhost:3000/* (add others as needed).
